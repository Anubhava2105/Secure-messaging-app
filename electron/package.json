{
  "name": "secure-messaging-electron",
  "version": "1.0.0",
  "description": "Security-hardened Electron wrapper for Secure Messaging",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && electron .",
    "dev": "tsc && electron .",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "electron",
    "secure",
    "messaging"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.9.0"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "build": {
    "appId": "com.securemsg.app",
    "productName": "Secure Messaging",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "../client/dist/**/*"
    ],
    "mac": {
      "category": "public.app-category.social-networking"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
